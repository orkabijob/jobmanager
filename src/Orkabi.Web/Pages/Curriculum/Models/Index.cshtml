@page
@model Orkabi.Web.Pages.Curriculum.Models.IndexModel
@using Orkabi.Web.Modules.Curriculum
@{
    ViewData["Title"] = "דגמים";
}

<div class="dash-shell">
  <header class="glass glass--nav dash-topbar">
    <a href="/" class="dash-topbar__wordmark">עורקבי</a>
    <span class="dash-topbar__title">תכנית לימודים</span>
    <nav class="dash-topbar__user">
      <span>שלום</span>
      <a href="/Account/Logout" class="btn-ghost" style="font-size:var(--t-admin-meta);">יציאה</a>
    </nav>
  </header>

  <main class="dash-body">
    <nav class="subnav" aria-label="ניווט תכנית לימודים">
      <a class="subnav__item" href="/Curriculum">סקירה</a>
      <a class="subnav__item" href="/Curriculum/Syllabi">סילבוסים</a>
      <a class="subnav__item is-active" href="/Curriculum/Models">דגמים</a>
    </nav>

    <header class="list-head">
      <h1 class="page-head__title">דגמים</h1>
      <a class="btn-primary" href="/Curriculum/Models/Create">+ דגם חדש</a>
    </header>

    <div class="glass glass--tile people-panel" style="--lg-tile-shadow: var(--lg-shadow);">
      @if (!Model.Models.Any())
      {
        <div class="empty-state">
          <span class="empty-state__icon" aria-hidden="true">📚</span>
          <p class="empty-state__title">אין דגמים עדיין</p>
          <p class="empty-state__hint">צרו דגם כדי לשבץ אותו בסילבוסים.</p>
          <a class="btn-primary" href="/Curriculum/Models/Create">+ דגם חדש</a>
        </div>
      }
      else
      {
        <table class="data-table">
          <thead>
            <tr>
              <th scope="col">שם הדגם</th>
              <th scope="col">שיעורים צפויים</th>
              <th scope="col">חומר</th>
              <th scope="col">וידאו</th>
              <th scope="col" class="data-table__actions-col">פעולות</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var m in Model.Models)
            {
              <tr class="data-row">
                <td class="data-cell data-cell--primary">@m.Name</td>
                <td class="data-cell"><bdi class="num">@m.ExpectedLessonsToComplete</bdi></td>
                <td class="data-cell">
                  @if (!string.IsNullOrWhiteSpace(m.MaterialLink))
                  {
                    <a class="link-chip" href="@m.MaterialLink" target="_blank" rel="noopener">
                      חומר <span class="icon-directional" aria-hidden="true">↗</span>
                    </a>
                  }
                  else
                  {
                    <span>—</span>
                  }
                </td>
                <td class="data-cell">
                  @if (!string.IsNullOrWhiteSpace(m.VideoLink))
                  {
                    <a class="link-chip" href="@m.VideoLink" target="_blank" rel="noopener">
                      וידאו <span class="icon-directional" aria-hidden="true">↗</span>
                    </a>
                  }
                  else
                  {
                    <span>—</span>
                  }
                </td>
                <td class="data-cell data-cell--actions">
                  <a class="btn-ghost btn-ghost--sm" href="/Curriculum/Models/Edit/@m.Id">עריכה</a>
                </td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>
  </main>
</div>
