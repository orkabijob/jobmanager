@page
@model Orkabi.Web.Pages.Curriculum.IndexModel
@{
    ViewData["Title"] = "תכנית לימודים";
}

<div class="dash-shell">
  <header class="glass glass--nav dash-topbar">
    <a href="/" class="dash-topbar__wordmark">עורקבי</a>
    <span class="dash-topbar__title">תכנית לימודים</span>
    <nav class="dash-topbar__user">
      <span>שלום</span>
      <a href="/Account/Logout" class="btn-ghost" style="font-size:var(--t-admin-meta);">יציאה</a>
    </nav>
  </header>

  <main class="dash-body">
    <nav class="subnav" aria-label="ניווט תכנית לימודים">
      <a class="subnav__item is-active" href="/Curriculum">סקירה</a>
      <a class="subnav__item" href="/Curriculum/Syllabi">סילבוסים</a>
      <a class="subnav__item" href="/Curriculum/Models">דגמים</a>
    </nav>

    <header class="page-head">
      <div>
        <h1 class="page-head__title">תכנית לימודים</h1>
        <p class="page-head__sub">סילבוסים ודגמי הוראה</p>
      </div>
    </header>

    <div class="glass glass--tile people-panel hub-grid" style="--lg-tile-shadow: var(--lg-shadow);">
      <a class="nav-card" href="/Curriculum/Syllabi">
        <span class="nav-card__icon" aria-hidden="true">📋</span>
        <span class="nav-card__title">סילבוסים</span>
        <span class="nav-card__desc">תכניות לימוד עם סדר דגמים מוגדר</span>
        <span class="nav-card__count"><span class="icon-directional" aria-hidden="true">←</span></span>
      </a>
      <a class="nav-card" href="/Curriculum/Models">
        <span class="nav-card__icon" aria-hidden="true">📚</span>
        <span class="nav-card__title">דגמים</span>
        <span class="nav-card__desc">יחידות לימוד לשיבוץ בסילבוסים</span>
        <span class="nav-card__count"><span class="icon-directional" aria-hidden="true">←</span></span>
      </a>
    </div>
  </main>
</div>
